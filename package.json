{
  "name": "play-pen-house",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && vite",
    "dev:frontend": "cd frontend && vite",
    "dev:backend": "wrangler pages dev . --port 8788",
    "dev:full": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "cd frontend && tsc -b && vite build",
    "preview": "wrangler pages dev ./frontend/dist",
    "deploy": "npm run build && wrangler pages deploy ./frontend/dist",
    "lint": "cd frontend && eslint .",
    "db:generate": "cd backend && drizzle-kit generate",
    "db:migrate": "cd backend && drizzle-kit migrate",
    "db:studio": "cd backend && drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.16.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.0.0"
  }
}
